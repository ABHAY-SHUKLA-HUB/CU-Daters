# =========================================
# SEEU-DATERS - SAFE TEMPLATE
# PUSH THIS FILE TO GITHUB
# =========================================

# ========= SERVER =========
NODE_ENV=development
PORT=5000

# ========= URLS =========
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5000
VITE_APP_URL=http://localhost:5173
VITE_API_URL=http://localhost:5000
SOCKET_URL=http://localhost:5000

# ========= DATABASE =========
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/DB_NAME

# ========= JWT =========
JWT_SECRET=your_super_secret_jwt_key
JWT_EXPIRY=7d

# ========= FIREBASE BACKEND =========
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-client-email
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com

# ========= FIREBASE FRONTEND =========
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# ========= STORAGE =========
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-bucket-name

# ========= PAYMENTS =========
UPI_ID=yourupi@upi
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# ========= EMAIL =========
# CRITICAL: Gmail SMTP Configuration for OTP Emails
#
# ⚠️  IMPORTANT SETUP STEPS:
# 1. Go to myaccount.google.com/security
# 2. Enable "2-Step Verification" (if not already enabled)
# 3. Go to myaccount.google.com/apppasswords
# 4. Select "Mail" and "Windows Computer" (or your device)
# 5. Click "Generate" to get a 16-character password
# 6. Copy the password WITHOUT SPACES (the service removes them automatically)
# 7. Set EMAIL_USER to your Gmail address
# 8. Set EMAIL_PASSWORD to the 16-character app password
#
# ❌ DO NOT use your regular Gmail password - use the App Password only!
# ❌ DO NOT generate credentials without 2FA enabled!

EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=abcdefghijklmnop

# SMTP Server Configuration (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_RETRIES=3

EMAIL_FROM=your-email@gmail.com

# ========= ADMIN =========
ADMIN_EMAIL=admin@example.com
ADMIN_PHONE=9999999999

# ========= FEATURES =========
FCM_ENABLED=false
EMAIL_NOTIFICATIONS_ENABLED=true
PUSH_NOTIFICATIONS_ENABLED=true
FRAUD_DETECTION_ENABLED=true
FRAUD_SCORE_THRESHOLD=60
AUTO_APPROVE_THRESHOLD=30
AUTO_REJECT_THRESHOLD=85

# ========= LOGGING =========
LOG_LEVEL=info
LOG_FORMAT=json

# ========= RATE LIMIT =========
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ========= CORS =========
CORS_ORIGIN=http://localhost:5173,http://localhost:3000